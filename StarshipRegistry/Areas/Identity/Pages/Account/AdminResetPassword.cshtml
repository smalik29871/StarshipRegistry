@page
@model AdminResetPasswordModel
@{
    ViewData["Title"] = "Issue Reset Clearance";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">

        <div class="text-center mb-4">
            <i class="bi bi-key-fill display-2 text-warning sw-glow-icon"></i>
            <h1 class="mt-3 fs-4 text-warning">Issue Reset Clearance</h1>
            <p class="text-secondary small letter-spaced">Generate a one-time password reset link for an agent</p>
        </div>

        <div class="card p-4">

            @if (Model.ResetLink != null)
            {
                <div class="alert alert-success small py-3">
                    <i class="bi bi-check-circle me-2"></i>
                    <strong>Reset link generated.</strong>
                    Share it with the agent via a secure channel (Slack, Teams, etc.) — never plain email.
                    It expires in <strong>24 hours</strong> and can only be used once.
                </div>

                <div class="mb-3">
                    <label class="form-label text-secondary small">One-time reset link</label>
                    <div class="input-group">
                        <input type="text" id="resetLinkInput" class="form-control form-control-sm font-monospace"
                               value="@Model.ResetLink" readonly />
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                onclick="navigator.clipboard.writeText(document.getElementById('resetLinkInput').value)"
                                title="Copy to clipboard">
                            <i class="bi bi-clipboard"></i>
                        </button>
                    </div>
                </div>

                <a asp-page="./AdminResetPassword" class="btn btn-outline-primary w-100 mt-1">
                    <i class="bi bi-arrow-repeat me-2"></i>Generate Another
                </a>
            }
            else
            {
                @if (Model.UserNotFound)
                {
                    <div class="alert alert-warning small py-2">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        No agent account found for that email address.
                    </div>
                }

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label"></label>
                        <input asp-for="Input.Email" class="form-control" placeholder="agent@empire.com" autocomplete="email" />
                        <div class="mt-1 text-secondary" style="font-size:0.7rem;letter-spacing:1px;">
                            <i class="bi bi-shield-lock me-1"></i>Deliver the link via Slack, Teams, or another secure channel — not plain email
                        </div>
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-key me-2"></i>Generate Reset Link
                    </button>
                </form>
            }

        </div>

    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
