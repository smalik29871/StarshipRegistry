@page
@model LoginModel
@{
    ViewData["Title"] = "Imperial Access Terminal";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">

        <div class="text-center mb-4">
            <i class="bi bi-heptagon-fill display-2 text-warning sw-glow-icon"></i>
            <h1 class="mt-3 fs-4 text-warning">Imperial Access Terminal</h1>
            <p class="text-secondary small letter-spaced">Restricted to authorised personnel only</p>
        </div>

        <div class="card p-4">
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label"></label>
                    <input asp-for="Input.Email" class="form-control" placeholder="agent@empire.com" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label"></label>
                    <input asp-for="Input.Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label">Remember this terminal</label>
                </div>

                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Access Terminal
                </button>
            </form>

            <hr class="border-secondary mt-4" />

            <p class="text-center small mt-2 mb-0">
                New recruit?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-warning">Request Imperial Access</a>
            </p>
            <p class="text-center small mt-2 mb-0 text-secondary">
                Credentials forgotten? Contact your Imperial Commander to have a reset link issued.
            </p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
