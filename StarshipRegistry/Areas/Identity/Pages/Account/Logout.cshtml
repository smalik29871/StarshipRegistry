@page
@model LogoutModel
@{
    ViewData["Title"] = "Terminal Disconnected";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4 text-center">
        <div class="card p-5">
            <i class="bi bi-box-arrow-left display-2 text-warning sw-glow-icon mb-3"></i>
            <h2 class="text-warning">Terminal Disconnected</h2>
            <p class="text-secondary mt-2">You have been logged out of the Imperial Command Network.</p>
            <a asp-page="./Login" class="btn btn-outline-primary mt-3">
                <i class="bi bi-box-arrow-in-right me-2"></i>Reconnect
            </a>
        </div>
    </div>
</div>
