@{
    ViewData["Title"] = "Imperial Command";
}

<div class="container mt-5">
    <div class="row text-center mb-5">
        <div class="col">
            <h1 class="display-4">Imperial Command Center</h1>
            <p class="lead text-muted">Fleet Management & Asset Registry Dashboard</p>
        </div>
    </div>

    @* Stat Cards Grid *@
    <div class="row g-4 mb-5">
        @* Total Ships Card *@
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body py-4">
                    <i class="bi bi-rocket-takeoff display-6 text-warning mb-2"></i>
                    <h5 class="text-uppercase text-secondary small">Total Fleet Ships</h5>
                    <h2 class="display-5 text-warning">@ViewBag.TotalShips</h2>
                </div>
            </div>
        </div>

        @* Total Cost Card *@
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body py-4">
                    <i class="bi bi-coin display-6 text-warning mb-2"></i>
                    <h5 class="text-uppercase text-secondary small">Total Assets Value</h5>
                    <h2 class="display-6 text-warning">@(ViewBag.TotalCost > 0 ? ViewBag.TotalCost.ToString("N0") + " Cr" : "0 Cr")</h2>
                </div>
            </div>
        </div>

        @* Top Rated Ship Card *@
        <div class="col-md-4">
            <div class="card h-100 shadow-sm text-center">
                <div class="card-body py-4">
                    <i class="bi bi-stars display-6 text-warning mb-2"></i>
                    <h5 class="text-uppercase text-secondary small">Fastest Class</h5>
                    <h2 class="fs-4 text-warning mt-2">@ViewBag.TopSpeedShip</h2>
                </div>
            </div>
        </div>
    </div>

    @* Quick Actions *@
    <div class="row justify-content-center g-4">
        <div class="col-md-6 text-center">
            <div class="card">
                <div class="card-body p-5">
                    <h3 class="mb-3">Access Registry</h3>
                    <p class="text-muted mb-4">Proceed to the starship database to query, filter, or sync live Imperial asset data directly from the external holonet.</p>
                    <a asp-controller="Starship" asp-action="Index" class="btn btn-outline-primary btn-lg px-4">
                        <i class="bi bi-terminal-fill me-2"></i> Open Command Registry
                    </a>
                </div>
            </div>
        </div>

        @* Recruit Liaison Card *@
        <div class="col-md-6 text-center">
            <div class="card h-100">
                <div class="card-body p-5">
                    <i class="bi bi-person-fill-add display-6 text-warning mb-3"></i>
                    <h3 class="mb-1">Enlist a New Agent</h3>
                    <p class="text-muted mb-4 small">
                        Share this Imperial Access Code with a recruit.<br />
                        They must enter it on the <a asp-area="Identity" asp-page="/Account/Register" class="text-warning">Register</a> page to create an account.
                    </p>

                    @if (!string.IsNullOrEmpty(ViewBag.RegistrationCode as string))
                    {
                        <div class="input-group">
                            <input id="inviteCode"
                                   type="text"
                                   class="form-control text-center font-monospace"
                                   value="@ViewBag.RegistrationCode"
                                   readonly />
                            <button class="btn btn-outline-primary"
                                    type="button"
                                    onclick="copyInviteCode()"
                                    title="Copy to clipboard">
                                <i class="bi bi-clipboard" id="copyIcon"></i>
                            </button>
                        </div>
                        <p id="copyFeedback" class="small mt-2 text-warning" style="min-height:1.2rem;"></p>
                    }
                    else
                    {
                        <p class="text-secondary small">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            No access code configured. Set <code>Auth:RegistrationCode</code> in your app settings or User Secrets.
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function copyInviteCode() {
        const input = document.getElementById('inviteCode');
        navigator.clipboard.writeText(input.value).then(() => {
            const icon = document.getElementById('copyIcon');
            const feedback = document.getElementById('copyFeedback');
            icon.className = 'bi bi-clipboard-check';
            feedback.textContent = 'Code copied to clipboard!';
            setTimeout(() => {
                icon.className = 'bi bi-clipboard';
                feedback.textContent = '';
            }, 2500);
        });
    }
</script>
}