@using StarshipRegistry.Helpers
@inject DetailsHelper DetailsHelper

@model StarshipRegistry.Models.ViewModels.PeopleDetailsViewModel

@{
    string mode = ViewData["PageMode"]?.ToString() ?? "Details";
    bool isEditMode = mode == "Edit";

    ViewData["Title"] = "Personnel File - " + Model.Character.Name;
}

<div class="container mt-4 pb-5">
    <div class="mb-4">
        @{
            string returnUrl = ViewData["ReturnUrl"]?.ToString() ?? "";
            if (!string.IsNullOrEmpty(returnUrl) && !Url.IsLocalUrl(returnUrl)) returnUrl = "";
            string backUrl = !string.IsNullOrEmpty(returnUrl) ? returnUrl : Url.Action("Index", "Starship") ?? "/";
        }
        <a href="@backUrl" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    @* Form wrapper *@
    <form asp-action="Edit" method="post">
        @* Header *@
        <div class="text-center mb-5 d-flex justify-content-between align-items-center">
            <div class="flex-grow-1">
                <span class="text-uppercase text-warning font-monospace small">Galactic Personnel Registry</span>
                @if (isEditMode)
                {
                    <input type="text" name="Name" class="form-control form-control-lg bg-dark text-info border-info fs-3 mt-1" value="@Model.Character.Name" required />
                }
                else
                {
                    <h1 class="display-4 text-info">@Model.Character.Name</h1>
                }
            </div>

            <div class="ms-3">
                @if (isEditMode)
                {
                    <button type="submit" class="btn btn-outline-success">
                        <i class="bi bi-check-lg me-1"></i> Save Changes
                    </button>
                    <a href="@(!string.IsNullOrEmpty(returnUrl) ? returnUrl : Url.Action("Details", "People", new { id = Model.Character.Url?.TrimEnd('/').Split('/').Last() }) ?? "/People")" class="btn btn-outline-secondary">Cancel</a>
                }
                else
                {
                    <a href="@Url.Action("Details", "People", new { id = Model.Character.Url?.TrimEnd('/').Split('/').Last(), edit = true, returnUrl = returnUrl })" class="btn btn-outline-info">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                }
            </div>
        </div>

        @* Hidden fields *@
        @if (isEditMode)
        {
            <input type="hidden" name="Url" value="@Model.Character.Url" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="row">
            @* Left Column: Physical Traits *@
            <div class="col-lg-7">
                <div class="card bg-dark text-white border-secondary mb-4 shadow">
                    <div class="card-header border-secondary bg-black">
                        <h5 class="mb-0 text-info font-monospace"><i class="bi bi-person-lines-fill me-2"></i>Biometric Data</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Birth Year</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="BirthYear" class="form-control bg-dark text-white border-secondary" value="@Model.Character.BirthYear" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Character.BirthYear</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Gender</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Gender" class="form-control bg-dark text-white border-secondary" value="@Model.Character.Gender" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Character.Gender</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Height</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Height" class="form-control bg-dark text-white border-secondary" value="@Model.Character.Height" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Character.Height cm</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Mass</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Mass" class="form-control bg-dark text-white border-secondary" value="@Model.Character.Mass" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Character.Mass kg</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Hair Color</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="HairColor" class="form-control bg-dark text-white border-secondary" value="@Model.Character.HairColor" />
                                }
                                else
                                {
                                    <p class="fs-5 text-capitalize">@Model.Character.HairColor</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Skin Tone</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="SkinColor" class="form-control bg-dark text-white border-secondary" value="@Model.Character.SkinColor" />
                                }
                                else
                                {
                                    <p class="fs-5 text-capitalize">@Model.Character.SkinColor</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Eye Color</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="EyeColor" class="form-control bg-dark text-white border-secondary" value="@Model.Character.EyeColor" />
                                }
                                else
                                {
                                    <p class="fs-5 text-capitalize">@Model.Character.EyeColor</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Right Column: Connected Data *@
            <div class="col-lg-5">
                <div class="card bg-dark text-white border-info shadow mb-4">
                    <div class="card-header border-info bg-black">
                        <h5 class="mb-0 text-warning font-monospace"><i class="bi bi-film me-2"></i>Appearances</h5>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        @if (isEditMode)
                        {
                            <div class="film-selector">
                                @{
                                    var availableFilms = ViewData["AvailableFilms"] as List<StarshipRegistry.Models.Film> ?? new();
                                }
                                @if (availableFilms.Any())
                                {
                                    <div class="list-group list-group-flush bg-dark">
                                        @foreach (var film in availableFilms.OrderByDescending(f => Model.Character.Films?.Contains(f.Url) ?? false))
                                        {
                                            bool isSelected = Model.Character.Films?.Contains(film.Url) ?? false;
                                            <label class="list-group-item bg-dark text-white border-secondary d-flex align-items-center gap-2 cursor-pointer">
                                                <input type="checkbox" name="selectedFilms" value="@film.Url" @(isSelected ? "checked" : "") class="form-check-input" />
                                                <span class="flex-grow-1">🎬 @film.Title</span>
                                            </label>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No films available in the database</p>
                                }
                            </div>
                        }
                        else if (Model.Character.Films.Any())
                        {
                            <div class="list-group list-group-flush bg-dark">
                                @foreach (var url in Model.Character.Films)
                                {
                                    var id = url.TrimEnd('/').Split('/').Last();
                                    var filmTitle = Model.FilmNames.TryGetValue(url, out var title) ? title : "Unknown Film";
                                    <a asp-controller="Film" asp-action="Details" asp-route-id="@id" class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                                        <span>🎬 @filmTitle</span>
                                        <i class="bi bi-chevron-right text-info small"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="card bg-dark text-white border-info shadow">
                    <div class="card-header border-info bg-black">
                        <h5 class="mb-0 text-warning font-monospace"><i class="bi bi-rocket-takeoff me-2"></i>Known Starships</h5>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        @if (isEditMode)
                        {
                            <div class="starship-selector">
                                @{
                                    var availableStarships = ViewData["AvailableStarships"] as List<StarshipRegistry.Models.Starship> ?? new();
                                }
                                @if (availableStarships.Any())
                                {
                                    <div class="list-group list-group-flush bg-dark">
                                        @foreach (var starship in availableStarships.OrderByDescending(s => Model.Character.Starships?.Contains(s.Url) ?? false))
                                        {
                                            bool isSelected = Model.Character.Starships?.Contains(starship.Url) ?? false;
                                            <label class="list-group-item bg-dark text-white border-secondary d-flex align-items-center gap-2 cursor-pointer">
                                                <input type="checkbox" name="selectedStarships" value="@starship.Url" @(isSelected ? "checked" : "") class="form-check-input" />
                                                <span class="flex-grow-1">🚀 @starship.Name</span>
                                            </label>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No starships available in the database</p>
                                }
                            </div>
                        }
                        else if (Model.Character.Starships.Any())
                        {
                            <div class="list-group list-group-flush bg-dark">
                                @foreach (var url in Model.Character.Starships)
                                {
                                    var id = url.TrimEnd('/').Split('/').Last();
                                    var starshipName = Model.StarshipNames.TryGetValue(url, out var name) ? name : "Unknown Starship";
                                    <a asp-controller="Starship" asp-action="Details" asp-route-id="@id" class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                                        <span>🚀 @starshipName</span>
                                        <i class="bi bi-chevron-right text-info small"></i>
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center py-3">No recorded flight logs.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>