@using StarshipRegistry.Helpers
@inject DetailsHelper DetailsHelper

@model StarshipRegistry.Models.ViewModels.PlanetDetailsViewModel

@{
    string mode = ViewData["PageMode"]?.ToString() ?? "Details";
    bool isEditMode = mode == "Edit";

    ViewData["Title"] = "Planet Survey - " + Model.Planet.Name;
}

<div class="container mt-4 pb-5">
    <div class="mb-4">
        @{
            var _rv = ViewData["ReturnUrl"]?.ToString() ?? "";
            string backUrl = (!string.IsNullOrEmpty(_rv) && Url.IsLocalUrl(_rv)) ? _rv : Url.Action("Index", "Starship") ?? "/";
        }
        <a href="@backUrl" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    @* Form wrapper *@
    <form asp-action="Edit" method="post">
        @* Header *@
        <div class="text-center mb-5 d-flex justify-content-between align-items-center">
            <div class="flex-grow-1">
                <span class="text-uppercase text-warning font-monospace small">Imperial Cartography Archives</span>
                @if (isEditMode)
                {
                    <input type="text" name="Name" class="form-control form-control-lg bg-dark text-info border-info fs-3 mt-1" value="@Model.Planet.Name" required />
                }
                else
                {
                    <h1 class="display-4 text-info">@Model.Planet.Name</h1>
                }
            </div>

            <div class="ms-3">
                @{
                    string returnUrl = ViewData["ReturnUrl"]?.ToString() ?? "";
                    if (!string.IsNullOrEmpty(returnUrl) && !Url.IsLocalUrl(returnUrl)) returnUrl = "";
                }
                @if (isEditMode)
                {
                    <button type="submit" class="btn btn-outline-success">
                        <i class="bi bi-check-lg me-1"></i> Save Changes
                    </button>
                    <a href="@(!string.IsNullOrEmpty(returnUrl) ? returnUrl : Url.Action("Details", "Planet", new { id = Model.Planet.Url?.TrimEnd('/').Split('/').Last() }))" class="btn btn-outline-secondary">Cancel</a>
                }
                else
                {
                    <a asp-action="Details" asp-route-id="@Model.Planet.Url?.TrimEnd('/').Split('/').Last()" asp-route-edit="true" asp-route-returnUrl="@returnUrl" class="btn btn-outline-info">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                }
            </div>
        </div>

        @* Hidden fields *@
        @if (isEditMode)
        {
            <input type="hidden" name="Url" value="@Model.Planet.Url" />
            <input type="hidden" name="returnUrl" value="@(ViewData["ReturnUrl"]?.ToString() ?? "")" />
        }

        <div class="row">
            @* Left Column: Planetary Conditions *@
            <div class="col-lg-7">
                <div class="card bg-dark text-white border-secondary mb-4 shadow">
                    <div class="card-header border-secondary bg-black">
                        <h5 class="mb-0 text-info font-monospace"><i class="bi bi-globe2 me-2"></i>Planet Environment</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Climate</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Climate" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.Climate" required />
                                }
                                else
                                {
                                    <p class="fs-5 text-capitalize">@Model.Planet.Climate</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Terrain</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Terrain" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.Terrain" />
                                }
                                else
                                {
                                    <p class="fs-5 text-capitalize">@Model.Planet.Terrain</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Population</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Population" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.Population" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Planet.Population</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Gravity</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Gravity" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.Gravity" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Planet.Gravity</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Diameter</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Diameter" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.Diameter" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Planet.Diameter km</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Rotation Period</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="RotationPeriod" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.RotationPeriod" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Planet.RotationPeriod hours</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Surface Water</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="SurfaceWater" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.SurfaceWater" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Planet.SurfaceWater%</p>
                                }
                            </div>
                            <div class="col-md-12">
                                <p class="text-white-50 mb-1">Orbital Period</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="OrbitalPeriod" class="form-control bg-dark text-white border-secondary" value="@Model.Planet.OrbitalPeriod" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Planet.OrbitalPeriod days</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Right Column: Connected Films *@
            <div class="col-lg-5">
                <div class="card bg-dark text-white border-info shadow mb-4">
                    <div class="card-header border-info bg-black">
                        <h5 class="mb-0 text-warning font-monospace"><i class="bi bi-film me-2"></i>Featured in Films</h5>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        @if (isEditMode)
                        {
                            <div class="film-selector">
                                @{
                                    var availableFilms = ViewData["AvailableFilms"] as List<StarshipRegistry.Models.Film> ?? new();
                                }
                                @if (availableFilms.Any())
                                {
                                    <div class="list-group list-group-flush bg-dark">
                                        @foreach (var film in availableFilms.OrderByDescending(f => Model.Planet.Films?.Contains(f.Url) ?? false))
                                        {
                                            bool isSelected = Model.Planet.Films?.Contains(film.Url) ?? false;
                                            <label class="list-group-item bg-dark text-white border-secondary d-flex align-items-center gap-2 cursor-pointer">
                                                <input type="checkbox" name="selectedFilms" value="@film.Url" @(isSelected ? "checked" : "") class="form-check-input" />
                                                <span class="flex-grow-1">🎬 @film.Title</span>
                                            </label>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No films available in the database</p>
                                }
                            </div>
                        }
                        else if (Model.Planet.Films.Any())
                        {
                            <div class="list-group list-group-flush bg-dark">
                                @foreach (var url in Model.Planet.Films)
                                {
                                    var id = url.TrimEnd('/').Split('/').Last();
                                    var filmTitle = Model.FilmNames.TryGetValue(url, out var title) ? title : "Unknown Film";
                                    <a asp-controller="Film" asp-action="Details" asp-route-id="@id" class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                                        <span>🎬 @filmTitle</span>
                                        <i class="bi bi-chevron-right text-info small"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>