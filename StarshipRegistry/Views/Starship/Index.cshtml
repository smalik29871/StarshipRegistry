@model IEnumerable<StarshipRegistry.Models.Starship>

@{
    ViewData["Title"] = "Starship Registry";
}

<div class="container-fluid mt-4 pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5">Starship Registry</h1>
        
        <div class="btn-group">
            <a asp-controller="Starship" asp-action="Create" class="btn btn-outline-primary">
                <i class="bi bi-plus-lg me-1"></i> Add Ship
            </a>
            
            @{ var syncCooldown = (int)(ViewBag.SyncCooldownSeconds ?? 0); }
            <form asp-controller="Starship" asp-action="Seed" method="post" class="d-inline">
                <button type="submit" id="syncBtn"
                    class="btn btn-outline-primary ms-2"
                    onclick="showLoader()"
                    data-cooldown="@syncCooldown"
                    @(syncCooldown > 0 ? "disabled" : "")>
                    <i class="bi bi-cloud-arrow-down-fill me-1"></i>
                    <span id="syncBtnText">Sync from SWAPI</span>
                </button>
            </form>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="mb-4">
        <div class="input-group">
            <span class="input-group-text bg-dark border-secondary text-info">
                <i class="bi bi-stars"></i>
            </span>
            <input type="text" id="aiSearchInput" class="form-control bg-dark text-white border-secondary" placeholder="Ask anything... e.g. 'most expensive ships' or 'rebel fighters'" />
            <button class="btn btn-outline-info" id="aiSearchBtn" type="button">
                <i class="bi bi-send me-1"></i> AI Search
            </button>
            <button class="btn btn-outline-secondary d-none" id="aiClearBtn" type="button">
                <i class="bi bi-x-lg me-1"></i> Clear
            </button>
        </div>
        <div id="aiSearchStatus" class="form-text text-info ms-1 d-none"></div>
    </div>

    <div class="card shadow-sm mb-5">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="starshipTable" class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Model</th>
                            <th>Class</th>
                            <th>Cost (Credits)</th>
                            <th>Crew</th>
                            <th>Hyperdrive</th>
                            <th>Created On</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-white border border-danger">
            <div class="modal-header border-secondary">
                <h5 class="modal-title text-danger">⚠️ Decertify Asset</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Delete" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="delete-id" />
                    <p>Are you certain you want to remove <span id="delete-name" class="fw-bold text-warning"></span> from the Imperial registry? This cannot be undone.</p>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-outline-danger">Confirm Deletion</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div id="holonet-loader" class="d-none position-fixed top-0 start-0 w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="background-color: rgba(11, 12, 16, 0.9); z-index: 9999;">
    <div class="spinner-border text-info mb-4" style="width: 4rem; height: 4rem; border-width: 0.25em;" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <h2 class="text-warning font-monospace" style="font-family: 'Orbitron', sans-serif !important;">ESTABLISHING HOLONET LINK...</h2>
    <p class="text-info font-monospace mt-2">Downloading starship registry assets from external archives.</p>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.0/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.4/css/responsive.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/2.3.0/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.0/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.4/js/dataTables.responsive.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.4/js/responsive.bootstrap5.min.js"></script>
    <script>
        const actionButtons = (id, name) => `
            <div class="btn-group btn-group-sm">
                <a href="/Starship/Details/${id}" class="btn btn-outline-success"><i class="bi bi-search"></i></a>
                <a href="/Starship/Details/${id}?edit=true" class="btn btn-outline-info"><i class="bi bi-pencil"></i></a>
                <button class="btn btn-outline-danger btn-delete-ship"
                    data-id="${id}" data-name="${encodeURIComponent(name)}">
                    <i class="bi bi-trash"></i>
                </button>
            </div>`;

        $(document).ready(function () {
            const tableOptions = {
                columns: [
                    { data: 'name', render: n => `<span class="fw-bold">${n}</span>` },
                    { data: 'model' },
                    { data: 'starshipClass', render: v => `<span class="text-capitalize">${v}</span>` },
                    { data: 'costInCredits' },
                    { data: 'crew' },
                    { data: 'hyperdriveRating' },
                    { data: 'created' },
                    { data: 'id', orderable: false, searchable: false, render: (id, _, row) => actionButtons(id, row.name) }
                ],
                columnDefs: [
                    { responsivePriority: 1, targets: 0 },
                    { responsivePriority: 1, targets: 7 }
                ],
                layout: {
                    topStart: 'pageLength',
                    topEnd: null
                }
            };

            const createServerTable = () => $('#starshipTable').DataTable({
                ...tableOptions,
                responsive: true,
                serverSide: true,
                processing: true,
                ajax: '/Starship/DataTable',
                language: {
                    search: '<i class="bi bi-search"></i>',
                    searchPlaceholder: 'Search name, model, class...',
                    processing: '<div class="text-info">Loading fleet data...</div>'
                }
            });

            const createClientTable = data => $('#starshipTable').DataTable({
                ...tableOptions,
                responsive: true,
                data,
                language: { search: '<i class="bi bi-search"></i>' }
            });

            let table = createServerTable();

            $('#starshipTable').on('click', '.btn-delete-ship', function () {
                document.getElementById('delete-id').value = $(this).data('id');
                document.getElementById('delete-name').innerText = decodeURIComponent($(this).data('name'));
                $('#deleteModal').modal('show');
            });

            async function runAiSearch() {
                const query = document.getElementById('aiSearchInput').value.trim();
                const status = document.getElementById('aiSearchStatus');
                const clearBtn = document.getElementById('aiClearBtn');
                const searchBtn = document.getElementById('aiSearchBtn');

                if (!query) {
                    restoreServerTable();
                    return;
                }

                status.textContent = 'Querying Holonet AI...';
                status.classList.remove('d-none', 'text-danger');
                status.classList.add('text-info');
                searchBtn.disabled = true;

                try {
                    const res = await fetch(`/Starship/AiSearch?query=${encodeURIComponent(query)}`);
                    if (!res.ok) {
                        throw new Error('AI search request failed.');
                    }

                    const ships = await res.json();

                    // Switch to client-side mode to display AI results
                    table.destroy();
                    $('#starshipTable tbody').empty();
                    table = createClientTable(ships);

                    status.textContent = `${ships.length} result(s) returned by AI.`;
                    clearBtn.classList.remove('d-none');
                } catch {
                    status.textContent = 'AI search failed. Try again.';
                    status.classList.replace('text-info', 'text-danger');
                } finally {
                    searchBtn.disabled = false;
                }
            }

            function restoreServerTable() {
                const status = document.getElementById('aiSearchStatus');
                const clearBtn = document.getElementById('aiClearBtn');

                if ($.fn.DataTable.isDataTable('#starshipTable')) {
                    table.destroy();
                }

                $('#starshipTable tbody').empty();
                document.getElementById('aiSearchInput').value = '';
                status.classList.add('d-none');
                status.classList.remove('text-danger');
                status.classList.add('text-info');
                clearBtn.classList.add('d-none');
                table = createServerTable();
            }

            document.getElementById('aiSearchBtn').addEventListener('click', runAiSearch);
            document.getElementById('aiSearchInput').addEventListener('keydown', e => { if (e.key === 'Enter') runAiSearch(); });
            document.getElementById('aiClearBtn').addEventListener('click', restoreServerTable);
        });

        function populateDeleteModal(id, name) {
            document.getElementById('delete-id').value = id;
            document.getElementById('delete-name').innerText = name;
        }

        function showLoader() {
            document.getElementById('holonet-loader').classList.remove('d-none');
        }

        (function () {
            const btn = document.getElementById('syncBtn');
            if (!btn) return;
            let remaining = parseInt(btn.dataset.cooldown, 10) || 0;
            if (remaining <= 0) return;
            const textEl = document.getElementById('syncBtnText');
            function fmt(s) {
                return Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0');
            }
            (function tick() {
                if (remaining <= 0) {
                    btn.disabled = false;
                    textEl.textContent = 'Sync from SWAPI';
                    return;
                }
                textEl.textContent = 'Sync from SWAPI (' + fmt(remaining) + ')';
                remaining--;
                setTimeout(tick, 1000);
            })();
        })();
    </script>
}
