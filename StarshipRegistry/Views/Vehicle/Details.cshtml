@using StarshipRegistry.Helpers
@inject DetailsHelper DetailsHelper

@model StarshipRegistry.Models.ViewModels.VehicleDetailsViewModel

@{
    string mode = ViewData["PageMode"]?.ToString() ?? "Details";
    bool isEditMode = mode == "Edit";

    ViewData["Title"] = "Vehicle Manifest - " + Model.Vehicle.Name;
}

<div class="container mt-4 pb-5">
    <div class="mb-4">
        @{
            string returnUrl = ViewData["ReturnUrl"]?.ToString() ?? "";
            string backUrl = !string.IsNullOrEmpty(returnUrl) ? returnUrl : Url.Action("Index", "Starship") ?? "/";
        }
        <a href="@backUrl" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    @* Form wrapper *@
    <form asp-action="Edit" method="post">
        @* Header *@
        <div class="text-center mb-5 d-flex justify-content-between align-items-center">
            <div class="flex-grow-1">
                <span class="text-uppercase text-warning font-monospace small">Planetary Transport Registry</span>
                @if (isEditMode)
                {
                    <input type="text" name="Name" class="form-control form-control-lg bg-dark text-info border-info fs-3 mt-1" value="@Model.Vehicle.Name" required />
                }
                else
                {
                    <h1 class="display-4 text-info">@Model.Vehicle.Name</h1>
                }
            </div>

            <div class="ms-3">
                @if (isEditMode)
                {
                    <button type="submit" class="btn btn-outline-success">
                        <i class="bi bi-check-lg me-1"></i> Save Changes
                    </button>
                    <a href="@(!string.IsNullOrEmpty(returnUrl) ? returnUrl : Url.Action("Details", "Vehicle", new { id = Model.Vehicle.Url?.TrimEnd('/').Split('/').Last() }) ?? "/Vehicle")" class="btn btn-outline-secondary">Cancel</a>
                }
                else
                {
                    <a asp-action="Details" asp-route-id="@Model.Vehicle.Url?.TrimEnd('/').Split('/').Last()" asp-route-edit="true" asp-route-returnUrl="@returnUrl" class="btn btn-outline-info">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </a>
                }
            </div>
        </div>

        @* Hidden fields *@
        @if (isEditMode)
        {
            <input type="hidden" name="Url" value="@Model.Vehicle.Url" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />
        }

        <div class="row">
            @* Left Column: Specs *@
            <div class="col-lg-7">
                <div class="card bg-dark text-white border-secondary mb-4 shadow">
                    <div class="card-header border-secondary bg-black">
                        <h5 class="mb-0 text-info font-monospace"><i class="bi bi-truck me-2"></i>Technical Specifications</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Model</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Model" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.Model" required />
                                }
                                else
                                {
                                    <p class="fs-6">@Model.Vehicle.Model</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Class</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="VehicleClass" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.VehicleClass" />
                                }
                                else
                                {
                                    <p class="fs-6">@Model.Vehicle.VehicleClass</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Manufacturer</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Manufacturer" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.Manufacturer" />
                                }
                                else
                                {
                                    <p class="fs-6">@Model.Vehicle.Manufacturer</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Cost</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="CostInCredits" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.CostInCredits" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Vehicle.CostInCredits credits</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Length</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Length" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.Length" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Vehicle.Length m</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Crew</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Crew" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.Crew" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Vehicle.Crew</p>
                                }
                            </div>
                            <div class="col-md-4">
                                <p class="text-white-50 mb-1">Passengers</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="Passengers" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.Passengers" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Vehicle.Passengers</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Max Atmosphering Speed</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="MaxAtmospheringSpeed" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.MaxAtmospheringSpeed" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Vehicle.MaxAtmospheringSpeed</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <p class="text-white-50 mb-1">Cargo Capacity</p>
                                @if (isEditMode)
                                {
                                    <input type="text" name="CargoCapacity" class="form-control bg-dark text-white border-secondary" value="@Model.Vehicle.CargoCapacity" />
                                }
                                else
                                {
                                    <p class="fs-5">@Model.Vehicle.CargoCapacity</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Right Column: Links *@
            <div class="col-lg-5">
                <div class="card bg-dark text-white border-info shadow mb-4">
                    <div class="card-header border-info bg-black">
                        <h5 class="mb-0 text-warning font-monospace"><i class="bi bi-person-badge me-2"></i>Known Operators</h5>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        @if (isEditMode)
                        {
                            <div class="pilot-selector">
                                @{
                                    var availableCharacters = ViewData["AvailableCharacters"] as List<StarshipRegistry.Models.Character> ?? new();
                                }
                                @if (availableCharacters.Any())
                                {
                                    <div class="list-group list-group-flush bg-dark">
                                        @foreach (var character in availableCharacters.OrderByDescending(c => Model.Vehicle.Pilots?.Contains(c.Url) ?? false))
                                        {
                                            bool isSelected = Model.Vehicle.Pilots?.Contains(character.Url) ?? false;
                                            <label class="list-group-item bg-dark text-white border-secondary d-flex align-items-center gap-2 cursor-pointer">
                                                <input type="checkbox" name="selectedPilots" value="@character.Url" @(isSelected ? "checked" : "") class="form-check-input" />
                                                <span class="flex-grow-1">👤 @character.Name</span>
                                            </label>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No characters available in the database</p>
                                }
                            </div>
                        }
                        else if (Model.Vehicle.Pilots.Any())
                        {
                            <div class="list-group list-group-flush bg-dark">
                                @foreach (var url in Model.Vehicle.Pilots)
                                {
                                    var id = url.TrimEnd('/').Split('/').Last();
                                    var characterName = Model.PilotNames.TryGetValue(url, out var name) ? name : "Unknown Pilot";
                                    <a asp-controller="People" asp-action="Details" asp-route-id="@id" class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                                        <span>👤 @characterName</span>
                                        <i class="bi bi-chevron-right text-info small"></i>
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center py-3">No specific pilots on record.</p>
                        }
                    </div>
                </div>

                <div class="card bg-dark text-white border-info shadow">
                    <div class="card-header border-info bg-black">
                        <h5 class="mb-0 text-info font-monospace"><i class="bi bi-film me-2"></i>Featured Films</h5>
                    </div>
                    <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                        @if (isEditMode)
                        {
                            <div class="film-selector">
                                @{
                                    var availableFilms = ViewData["AvailableFilms"] as List<StarshipRegistry.Models.Film> ?? new();
                                }
                                @if (availableFilms.Any())
                                {
                                    <div class="list-group list-group-flush bg-dark">
                                        @foreach (var film in availableFilms.OrderByDescending(f => Model.Vehicle.Films?.Contains(f.Url) ?? false))
                                        {
                                            bool isSelected = Model.Vehicle.Films?.Contains(film.Url) ?? false;
                                            <label class="list-group-item bg-dark text-white border-secondary d-flex align-items-center gap-2 cursor-pointer">
                                                <input type="checkbox" name="selectedFilms" value="@film.Url" @(isSelected ? "checked" : "") class="form-check-input" />
                                                <span class="flex-grow-1">🎬 @film.Title</span>
                                            </label>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">No films available in the database</p>
                                }
                            </div>
                        }
                        else if (Model.Vehicle.Films.Any())
                        {
                            <div class="list-group list-group-flush bg-dark">
                                @foreach (var url in Model.Vehicle.Films)
                                {
                                    var id = url.TrimEnd('/').Split('/').Last();
                                    var filmTitle = Model.FilmNames.TryGetValue(url, out var title) ? title : "Unknown Film";
                                    <a asp-controller="Film" asp-action="Details" asp-route-id="@id" class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex justify-content-between align-items-center">
                                        <span>🎬 @filmTitle</span>
                                        <i class="bi bi-chevron-right text-info small"></i>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>